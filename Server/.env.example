

# General / Required for all environments
NODE_ENV=development          # production | staging | development
PORT=5000                     # Server port (default 5000)

# Database (MongoDB – Mongoose)
MONGO_URI=mongodb://localhost:27017/yourdbname

# Authentication & Security
JWT_SECRET=your_super_long_random_secret_here_change_this_very_important
JWT_EXPIRES_IN=30d            # Access token expiry (e.g. 15m, 1h, 7d, 30d)

# Refresh token (optional if using)
REFRESH_TOKEN_SECRET=another_very_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=90d

# Email (Nodemailer)
EMAIL_SERVICE=gmail           # gmail | sendgrid | outlook etc.
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_app_specific_password_or_api_key

# 2FA / QR Code (speakeasy + qrcode)
APP_URL=http://localhost:5000

# Rate Limiting / Other
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100            # max requests per window

# =====================================
# Production / Optional advanced
# =====================================
# TRUST_PROXY=true            # If behind proxy (Heroku, Vercel, Nginx)
# COOKIE_DOMAIN=yourdomain.com